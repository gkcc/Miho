{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.miyo/schemas/zzz_export_image_draft.schema.json",
  "title": "ZZZ Official Export Image Draft",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "game",
    "source_type",
    "character",
    "stats",
    "skill_levels",
    "equipment",
    "drive_discs",
    "warnings",
    "uncertain"
  ],
  "properties": {
    "game": {
      "const": "zzz"
    },
    "source_type": {
      "const": "official_export_image"
    },
    "character": {
      "type": "object",
      "required": ["name", "level", "rank"],
      "properties": {
        "name": {
          "$ref": "#/$defs/textField"
        },
        "level": {
          "$ref": "#/$defs/numberTextField"
        },
        "rank": {
          "$ref": "#/$defs/textField"
        }
      }
    },
    "stats": {
      "type": "object",
      "required": [
        "hp",
        "atk",
        "def",
        "impact",
        "crit_rate",
        "crit_dmg",
        "anomaly_mastery",
        "anomaly_proficiency",
        "pen",
        "energy_regen",
        "physical_dmg_bonus"
      ],
      "properties": {
        "hp": {
          "$ref": "#/$defs/numberTextField"
        },
        "atk": {
          "$ref": "#/$defs/numberTextField"
        },
        "def": {
          "$ref": "#/$defs/numberTextField"
        },
        "impact": {
          "$ref": "#/$defs/numberTextField"
        },
        "crit_rate": {
          "$ref": "#/$defs/numberTextField"
        },
        "crit_dmg": {
          "$ref": "#/$defs/numberTextField"
        },
        "anomaly_mastery": {
          "$ref": "#/$defs/numberTextField"
        },
        "anomaly_proficiency": {
          "$ref": "#/$defs/numberTextField"
        },
        "pen": {
          "$ref": "#/$defs/numberTextField"
        },
        "energy_regen": {
          "$ref": "#/$defs/numberTextField"
        },
        "physical_dmg_bonus": {
          "$ref": "#/$defs/numberTextField"
        }
      }
    },
    "skill_levels": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["slot", "level"],
        "properties": {
          "slot": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "level": {
            "$ref": "#/$defs/numberTextField"
          }
        }
      }
    },
    "equipment": {
      "type": "object",
      "required": ["name", "level", "rank"],
      "properties": {
        "name": {
          "$ref": "#/$defs/textField"
        },
        "level": {
          "$ref": "#/$defs/numberTextField"
        },
        "rank": {
          "$ref": "#/$defs/textField"
        }
      }
    },
    "drive_discs": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["slot", "set_name", "level", "main_stat", "sub_stats"],
        "properties": {
          "slot": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "set_name": {
            "$ref": "#/$defs/textField"
          },
          "level": {
            "$ref": "#/$defs/numberTextField"
          },
          "main_stat": {
            "$ref": "#/$defs/textField"
          },
          "sub_stats": {
            "$ref": "#/$defs/subStatsField"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertain": {
      "type": "boolean"
    }
  },
  "$defs": {
    "fieldBase": {
      "type": "object",
      "required": ["value", "uncertain", "evidence", "source_region"],
      "properties": {
        "uncertain": {
          "type": "boolean"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_region": {
          "type": ["string", "null"]
        }
      }
    },
    "textField": {
      "allOf": [
        {
          "$ref": "#/$defs/fieldBase"
        },
        {
          "properties": {
            "value": {
              "type": ["string", "null"]
            }
          }
        }
      ]
    },
    "numberTextField": {
      "allOf": [
        {
          "$ref": "#/$defs/fieldBase"
        },
        {
          "properties": {
            "value": {
              "type": ["string", "null"],
              "pattern": "^[0-9]+(?:\\.[0-9]+)?%?$"
            }
          }
        }
      ]
    },
    "subStatsField": {
      "allOf": [
        {
          "$ref": "#/$defs/fieldBase"
        },
        {
          "properties": {
            "value": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["stat", "value", "uncertain", "evidence"],
                "properties": {
                  "stat": {
                    "type": "string"
                  },
                  "value": {
                    "type": ["string", "null"]
                  },
                  "uncertain": {
                    "type": "boolean"
                  },
                  "evidence": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
